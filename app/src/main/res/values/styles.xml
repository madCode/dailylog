<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">#BEE3DB</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryDark">#BEE3DB</item>
        <item name="colorPrimaryVariant">#D0ECE6</item>
        <item name="colorSecondary">#94355E</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorAccent">#94355E</item>
        <item name="colorSecondaryVariant">#94355E</item>
    </style>
    
    <!-- Custom AlertDialog theme with primary button styling -->
    <style name="CustomAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MaterialComponents.Button</item>
    </style>
</resources>